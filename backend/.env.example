# Server
PORT=5000
NODE_ENV=development

# CORS - frontend origin
CLIENT_URL=http://localhost:5173

# PostgreSQL - LOCAL development (discrete vars, no SSL)
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=store_rating

# PostgreSQL - PRODUCTION (managed DB like Neon/Render). If set, this takes
# priority over the PG* vars above and enables SSL. Leave blank locally.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Auth
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=1d

# Default seeded admin account
SEED_ADMIN_NAME=System Administrator Account
SEED_ADMIN_EMAIL=admin@storerating.com
SEED_ADMIN_PASSWORD=Admin@12345
SEED_ADMIN_ADDRESS=HQ, Platform Street
